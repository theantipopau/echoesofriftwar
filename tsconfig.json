{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "node_modules",
    "src/scenes",
    "src/ui",
    "src/systems/tiles",
    "src/systems/abilities",
    "src/systems/combat",
    "src/systems/inventory",
    "src/systems/loot",
    "src/systems/visuals",
    "src/entities/Player.ts",
    "src/entities/Enemy.ts",
    "src/entities/NPC.ts",
    "src/entities/LootPickup.ts",
    "src/systems/game/LootSystem.ts",
    "src/systems/game/QuestTracker.ts",
    "src/systems/game/FeedbackText.ts"
  ]
}
